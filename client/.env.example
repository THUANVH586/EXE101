# Đổi tên file này thành .env trên local để dùng (không commit file .env lên Git)
# Trỏ về Backend đang chạy trên Render (thay URL này bằng URL Render của bạn cộng thêm /api)
# VITE_API_URL=https://conson-backend.onrender.com/api

# Hoặc trỏ về Backend localhost:
# VITE_API_URL=http://localhost:5000/api
